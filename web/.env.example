# Copy to .env.local to override defaults.

# Base URL for the FastAPI platform API. Leave empty to use same-origin + MSW mocks.
VITE_API_BASE=

# Set to "true" to disable the MSW mock layer (e.g. when the real backend is up).
VITE_DISABLE_MOCKS=

# Override the on-device leaf model (used as fallback). Defaults to the PlantVillage
# model on the Hugging Face CDN. Set LAYOUT=nhwc-raw for a model from ml/train_field_model.py.
VITE_LEAF_MODEL_URL=
VITE_LEAF_MODEL_LAYOUT=

# --- Cloud vision AI (most accurate on real photos) ---
# This is a SERVER-side key for the /api/leaf-scan function — set it in Vercel
# (Project → Settings → Environment Variables), NOT here and NOT with a VITE_ prefix
# (VITE_ vars are exposed to the browser). Get a free key: https://aistudio.google.com/apikey
#   GEMINI_API_KEY=your_key_here
#   GEMINI_MODEL=gemini-2.0-flash   (optional)
